{
	"name": "denfrievilje.dk",
	"version": "0.0.1",
	"description": "Den Frie Vilje Website",
	"type": "module",
	"engines": {
		"node": "~24.14.0",
		"pnpm": "~10.30.3"
	},
	"scripts": {
		"images": "node scripts/process-images.js",
		"dev": "node scripts/process-images.js && vite",
		"build": "node scripts/process-images.js && vite build",
		"preview": "vite preview",
		"test:e2e": "vitest run --config vitest.config.ts",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.0",
		"@sveltejs/kit": "^2.53.2",
		"@sveltejs/mcp": "^0.1.20",
		"@sveltejs/vite-plugin-svelte": "^4.0.0-next.6",
		"@tailwindcss/vite": "^4.2.1",
		"@typescript-eslint/eslint-plugin": "^8.0.0",
		"@typescript-eslint/parser": "^8.0.0",
		"eslint": "^9.0.0",
		"js-yaml": "^4.1.1",
		"prettier": "^3.0.0",
		"sharp": "^0.34.5",
		"sirv": "^2.0.0",
		"svelte": "^5.0.0",
		"svelte-check": "^3.0.0",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.0.0",
		"vite": "^5.0.0",
		"vitest": "^1.4.7"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp"
		]
	},
	"dependencies": {
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.3.3",
		"marked": "^17.0.3"
	}
}
